# App
DRISHTI_ENV=local
DRISHTI_API_HOST=0.0.0.0
DRISHTI_API_PORT=8000
DRISHTI_WEB_ORIGIN=http://localhost:3000
# Optional comma-separated additional origins, e.g. Vercel preview URLs.
DRISHTI_EXTRA_CORS_ORIGINS=

# Database / Supabase
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/drishti
DRISHTI_DB_POOL_SIZE=5
DRISHTI_DB_MAX_OVERFLOW=10
DRISHTI_DB_POOL_TIMEOUT_SECONDS=10
DRISHTI_DB_POOL_RECYCLE_SECONDS=1800
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis / Arq
REDIS_URL=redis://localhost:6379/0

# Auth / Clerk
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=
# Local-only demo token minting. Do not enable in production.
DRISHTI_ALLOW_LOCAL_DEMO_AUTH=false
DRISHTI_TEST_JWT_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.2
OPENAI_CHEAP_MODEL=gpt-5-mini

# Observability
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=drishti-api

# Connector transport mode: mock | live
DRISHTI_TRANSPORT=mock
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders,read_customers,read_products
SHOPIFY_REDIRECT_URI=
SHIPROCKET_WEBHOOK_SECRET=
RAZORPAY_WEBHOOK_SECRET=
